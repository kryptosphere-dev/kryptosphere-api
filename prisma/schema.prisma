generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  admin
  editor
  viewer
}

enum BoardType {
  main
  chapter
}

enum PartnerCategory {
  sponsor
  media
  community
  institutional
}

enum SponsorTier {
  platinum
  gold
  silver
  bronze
}

enum EventStatus {
  draft
  published
  cancelled
  archived
}

enum PublicationCategory {
  kryptopaper
  article
  rapport
  etude
}

// ─── AUTH ────────────────────────────────────────────────────────────────
// Authentication is delegated to Neon Auth (Stack Auth).
// authUserId references neon_auth.users_sync.id
// Email is NOT duplicated here — read it from neon_auth.users_sync to avoid drift.

model User {
  id         String             @id @default(uuid())
  authUserId String             @unique
  role       UserRole           @default(viewer)
  member     AssociationMember?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([role])
}

// ─── GÉOGRAPHIE ──────────────────────────────────────────────────────────

model Country {
  id       String    @id @default(uuid())
  code     String    @unique
  nameFr   String
  nameEn   String
  cities   City[]
  schools  School[]
  chapters Chapter[]
}

model City {
  id        String    @id @default(uuid())
  slug      String    @unique
  nameFr    String
  nameEn    String
  countryId String
  country   Country   @relation(fields: [countryId], references: [id])
  latitude  Float?
  longitude Float?
  schools   School[]
  chapters  Chapter[]
  events    Event[]

  @@index([countryId])
}

// ─── ÉCOLES / ANTENNES / BUREAUX / PÔLES ─────────────────────────────────

model School {
  id         String              @id @default(uuid())
  slug       String              @unique
  name       String
  address    String?
  postalCode String?
  cityId     String?
  city       City?               @relation(fields: [cityId], references: [id])
  countryId  String
  country    Country             @relation(fields: [countryId], references: [id])
  websiteUrl String?
  logoId     String?
  logo       Image?              @relation("SchoolLogo", fields: [logoId], references: [id])
  chapters   Chapter[]
  members    AssociationMember[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([cityId])
  @@index([countryId])
  @@index([logoId])
}

model Chapter {
  id                  String    @id @default(uuid())
  slug                String    @unique
  nameFr              String
  nameEn              String
  descriptionFr       String
  descriptionEn       String
  littleDescriptionFr String
  littleDescriptionEn String
  cityId              String
  city                City      @relation(fields: [cityId], references: [id])
  countryId           String
  country             Country   @relation(fields: [countryId], references: [id])
  schoolId            String?
  school              School?   @relation(fields: [schoolId], references: [id])
  latitude            Float?
  longitude           Float?
  heroImageId         String?
  heroImage           Image?    @relation("ChapterHero", fields: [heroImageId], references: [id])
  logoId              String?
  logo                Image?    @relation("ChapterLogo", fields: [logoId], references: [id])
  email               String?
  phone               String?
  address             String?
  establishedDate     DateTime?
  isActive            Boolean   @default(true)
  galleryId           String?   @unique
  gallery             Gallery?  @relation(fields: [galleryId], references: [id])
  boards              Board[]
  events              Event[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([schoolId])
  @@index([cityId])
  @@index([isActive])
  @@index([heroImageId])
  @@index([logoId])
}

model Board {
  id        String          @id @default(uuid())
  type      BoardType
  year      Int
  chapterId String?
  chapter   Chapter?        @relation(fields: [chapterId], references: [id])
  poles     Pole[]
  mandates  MemberMandate[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([type, year, chapterId])
  @@index([chapterId])
  @@index([year])
}

model Pole {
  id            String          @id @default(uuid())
  slug          String
  titleFr       String
  titleEn       String
  descriptionFr String[]
  descriptionEn String[]
  boardId       String
  board         Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  order         Int             @default(0)
  mandates      MemberMandate[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([boardId, slug])
  @@index([boardId])
}

model MemberRole {
  id            String          @id @default(uuid())
  slug          String          @unique
  nameFr        String
  nameEn        String
  descriptionFr String?
  descriptionEn String?
  mandates      MemberMandate[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model AssociationMember {
  id                  String          @id @default(uuid())
  firstName           String
  lastName            String
  email               String?         @unique
  pictureId           String?
  picture             Image?          @relation("MemberPicture", fields: [pictureId], references: [id])
  linkedinUrl         String?
  twitterUrl          String?
  descriptionFr       String?
  descriptionEn       String?
  schoolId            String?
  school              School?         @relation(fields: [schoolId], references: [id])
  userId              String?         @unique
  user                User?           @relation(fields: [userId], references: [id])
  cotisationPaid      Boolean         @default(false)
  cotisationStartDate DateTime?
  cotisationEndDate   DateTime?
  mandates            MemberMandate[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([schoolId])
  @@index([pictureId])
  @@index([lastName, firstName])
  @@index([cotisationPaid])
}

model MemberMandate {
  id        String            @id @default(uuid())
  memberId  String
  member    AssociationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  roleId    String
  role      MemberRole        @relation(fields: [roleId], references: [id])
  boardId   String
  board     Board             @relation(fields: [boardId], references: [id])
  poleId    String?
  pole      Pole?             @relation(fields: [poleId], references: [id])
  order     Int               @default(0)
  startDate DateTime          @default(now())
  endDate   DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([memberId, roleId, boardId])
  @@index([boardId])
  @@index([poleId])
  @@index([roleId])
  @@index([endDate])
}

// ─── CONTENU ÉDITORIAL ───────────────────────────────────────────────────

model Publication {
  id            String              @id @default(uuid())
  slug          String              @unique
  category      PublicationCategory
  titleFr       String
  titleEn       String
  descriptionFr String
  descriptionEn String
  dateLabelFr   String?
  dateLabelEn   String?
  readTimeFr    String?
  readTimeEn    String?
  publishedAt   DateTime?
  coverImageId  String?
  coverImage    Image?              @relation("PublicationCover", fields: [coverImageId], references: [id])
  downloadUrl   String?
  order         Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([category])
  @@index([publishedAt])
  @@index([coverImageId])
}

model TimelineEntry {
  id             String   @id @default(uuid())
  year           Int      @unique
  order          Int      @default(0)
  titleFr        String
  titleEn        String
  descriptionFr  String
  descriptionEn  String
  achievementsFr String[] @default([])
  achievementsEn String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AssociationSection {
  id      String @id @default(uuid())
  key     String @unique
  order   Int    @default(0)
  titleFr String
  titleEn String
  bodyFr  String
  bodyEn  String
}

model Stat {
  id       String  @id @default(uuid())
  key      String  @unique
  value    String
  iconName String?
  order    Int     @default(0)
  labelFr  String
  labelEn  String
}

// ─── EVENTS / SPEAKERS / SPONSORS / PARTNERS ─────────────────────────────

model Event {
  id            String             @id @default(uuid())
  slug          String             @unique
  titleFr       String
  titleEn       String
  subtitleFr    String?
  subtitleEn    String?
  descriptionFr String?
  descriptionEn String?
  dateLabelFr   String?
  dateLabelEn   String?
  status        EventStatus        @default(draft)
  startDate     DateTime
  endDate       DateTime?
  cityId        String?
  city          City?              @relation(fields: [cityId], references: [id])
  venue         String?
  chapterId     String?
  chapter       Chapter?           @relation(fields: [chapterId], references: [id])
  coverImageId  String?
  coverImage    Image?             @relation("EventCover", fields: [coverImageId], references: [id])
  lumaUrl       String?
  lumaEventId   String?            @unique
  internalRoute String?
  galleryId     String?            @unique
  gallery       Gallery?           @relation(fields: [galleryId], references: [id])
  sponsorships  EventSponsorship[]
  partnerships  EventPartnership[]
  speakers      EventSpeaker[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([startDate])
  @@index([status])
  @@index([chapterId])
  @@index([cityId])
  @@index([coverImageId])
}

model Speaker {
  id          String         @id @default(uuid())
  firstName   String
  lastName    String
  pictureId   String?
  picture     Image?         @relation("SpeakerPicture", fields: [pictureId], references: [id])
  linkedinUrl String?
  twitterUrl  String?
  roleFr      String?
  roleEn      String?
  companyFr   String?
  companyEn   String?
  bioFr       String?
  bioEn       String?
  events      EventSpeaker[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([lastName, firstName])
  @@index([pictureId])
}

model EventSpeaker {
  eventId   String
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speakerId String
  speaker   Speaker @relation(fields: [speakerId], references: [id])
  topic     String?
  order     Int     @default(0)

  @@id([eventId, speakerId])
  @@index([speakerId])
}

model Sponsor {
  id           String             @id @default(uuid())
  name         String             @unique
  websiteUrl   String?
  logoId       String?
  logo         Image?             @relation("SponsorLogo", fields: [logoId], references: [id])
  sponsorships EventSponsorship[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([logoId])
}

model EventSponsorship {
  eventId   String
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsorId String
  sponsor   Sponsor     @relation(fields: [sponsorId], references: [id])
  tier      SponsorTier
  amount    Decimal?    @db.Decimal(12, 2)
  currency  String?     @db.Char(3)
  notes     String?

  @@id([eventId, sponsorId])
  @@index([sponsorId])
  @@index([tier])
}

model Partner {
  id            String             @id @default(uuid())
  name          String             @unique
  websiteUrl    String?
  logoId        String?
  logo          Image?             @relation("PartnerLogo", fields: [logoId], references: [id])
  category      PartnerCategory
  descriptionFr String?
  descriptionEn String?
  events        EventPartnership[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([category])
  @@index([logoId])
}

model EventPartnership {
  eventId   String
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id])

  @@id([eventId, partnerId])
}

// ─── MEDIA ───────────────────────────────────────────────────────────────

model Image {
  id                String              @id @default(uuid())
  key               String              @unique
  url               String
  altText           String?
  description       String?
  schoolLogos       School[]            @relation("SchoolLogo")
  chapterHeroes     Chapter[]           @relation("ChapterHero")
  chapterLogos      Chapter[]           @relation("ChapterLogo")
  memberPictures    AssociationMember[] @relation("MemberPicture")
  speakerPictures   Speaker[]           @relation("SpeakerPicture")
  sponsorLogos      Sponsor[]           @relation("SponsorLogo")
  partnerLogos      Partner[]           @relation("PartnerLogo")
  publicationCovers Publication[]       @relation("PublicationCover")
  eventCovers       Event[]             @relation("EventCover")
  galleryItems      GalleryImage[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model Gallery {
  id        String         @id @default(uuid())
  items     GalleryImage[]
  chapter   Chapter?
  event     Event?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model GalleryImage {
  galleryId String
  gallery   Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  imageId   String
  image     Image   @relation(fields: [imageId], references: [id])
  order     Int     @default(0)
  caption   String?

  @@id([galleryId, imageId])
  @@index([imageId])
}
