# Neon Postgres
# Production branch: Neon Console → project → branch "production" → connection string
# Dev branch:        Neon Console → project → branch "dev" → connection string
DATABASE_URL=your_db_url

# Neon Auth — Neon Console → Auth → Configuration
NEON_AUTH_JWKS_URL=your_auth_base_url/.well-known/jwks.json

# Setup — one-time super admin promotion, generate with: openssl rand -base64 32
SETUP_SECRET=your_setup_secret_here

# Vercel Blob (image storage) — Vercel Dashboard → Storage → your Blob store
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
